{
  "name": "teams-for-m1",
  "version": "1.0.6",
  "main": "app/index.js",
  "description": "Unofficial client for Microsoft Teams for Mac",
  "homepage": "https://github.com/17hoehbr/teams-for-m1",
  "keywords": [
    "Teams",
    "Microsoft Teams"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://github.com/17hoehbr/teams-for-m1"
  },
  "author": {
    "name": "17hoehbr",
    "email": "17hoehbr@gmail.com",
    "url": "https://github.com/17hoehbr/"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint **/*.js",
    "start": "yarn install && electron ./app",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder"
  },
  "dependencies": {
    "electron-dl": "ismaelmartinez/electron-dl",
    "electron-editor-context-menu": "1.1.1",
    "electron-native-notification": "1.2.1",
    "electron-window-state": "5.0.3",
    "spellchecker": "3.7.1",
    "yargs": "16.0.0"
  },
  "devDependencies": {
    "electron": "12.0.0",
    "electron-builder": "^22.9.1",
    "eslint": "5.16.0",
    "yarn": "1.22.4"
  },
  "build": {
    "appId": "teams-for-m1",
    "asarUnpack": [
      "node_modules/spellchecker/vendor/hunspell_dictionaries"
    ],
    "protocols": {
      "name": "msteams",
      "schemes": [
        "msteams"
      ]
    },
    "mac": {
          "target" : { "target": "dir", "arch": "arm64" }
    }
  }
}
